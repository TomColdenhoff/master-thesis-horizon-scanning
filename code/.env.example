# LLM provider: "bedrock" (AWS) or "anthropic" (direct API)
LLM_PROVIDER=bedrock

# Model IDs (defaults match the values in config.py — override here if needed)
LLM_MODEL=eu.anthropic.claude-sonnet-4-6
CLASSIFIER_MODEL=eu.anthropic.claude-sonnet-4-6

# AWS Bedrock credentials (used when LLM_PROVIDER=bedrock)
# Option 1: explicit keys (local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=        # uncomment and set only for temporary credentials (SSO / assumed role)
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-1
# Option 2: IAM role (EC2 / ECS) — leave keys blank, SDK picks up the role automatically

# Anthropic direct API (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Text chunker
CHUNK_SIZE=500
CHUNK_OVERLAP=150

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=horizon_scanning
DB_USER=postgres
DB_PASSWORD=
